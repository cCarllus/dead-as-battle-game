{
  "name": "dead-as-battleground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ngrok": "vite --mode ngrok",
    "dev:server": "tsx watch server/src/index.ts",
    "game:server:dev": "concurrently -k -n SERVER,WEB -c cyan,yellow \"npm:dev:server\" \"npm:dev\"",
    "dev:all": "npm run game:server:dev",
    "start:server": "tsx server/src/index.ts",
    "build:server": "tsc --project server/tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/main.ts src/app/game-app.ts src/config/env.ts src/config/game.config.ts src/core/engine src/core/runtime src/core/scene src/debug/debug-tools.ts src/environment/create-test-environment.ts src/game/bootstrap src/game/states src/ui/create-hud.ts src/utils/dom.ts vite.config.ts",
    "lint:full": "eslint .",
    "format": "prettier --write .",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^8.56.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@babylonjs/core": "^8.56.1",
    "@babylonjs/gui": "^8.56.1",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/loaders": "^8.56.1",
    "@babylonjs/materials": "^8.56.1",
    "@colyseus/core": "^0.17.39",
    "@colyseus/sdk": "^0.17.34",
    "@colyseus/ws-transport": "^0.17.9",
    "bootstrap-icons": "^1.13.1",
    "express": "^5.2.1",
    "recast-detour": "^1.6.4",
    "zod": "^4.3.6"
  }
}
